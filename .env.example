# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OMDb (omdbapi.com) — for IMDb rating + RT critic score
VITE_OMDB_API_KEY=your-omdb-api-key

# TMDB API
VITE_TMDB_API_KEY=your-tmdb-api-key
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# Twilio (used in Supabase edge functions — set as Supabase secrets, not here)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# SerpAPI (showtime fallback)
# SERPAPI_KEY=your-serpapi-key

# AMC Developer API
# AMC_API_KEY=your-amc-api-key
